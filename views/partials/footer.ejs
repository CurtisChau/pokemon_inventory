                <option value="CNY">RMB</option>
             </select>
             <input type="number" step="0.01" id="bulk_sale_ship_conv_amt" class="input input-xs input-bordered w-full p-1 text-[10px]" placeholder="Amt" oninput="calcInlineConversion('bulk_sale_ship', 'bulk_sale_ship')" />
          </div>
        </label>
      </div>
      
      <div class="flex gap-2 w-full mt-2">
        <label class="form-control w-1/2">
          <div class="label py-0 pb-1"><span class="label-text text-[10px] font-bold text-base-content/70">Conducted By</span></div>
          <select name="person" class="select select-bordered select-sm" onchange="document.getElementById('bulk_sale_person_override').classList.toggle('hidden', this.value !== 'Other')" required>
            <option value="Curtis">Curtis</option>
            <option value="Michael">Michael</option>
            <option value="Other">Other (Manual)</option>
          </select>
        </label>
        <label class="form-control w-1/2 hidden" id="bulk_sale_person_override">
          <div class="label py-0 pb-1"><span class="label-text text-[10px] text-base-content/70">Custom Name</span></div>
          <input type="text" name="person_override" placeholder="Typing name..." class="input input-bordered input-sm w-full" />
        </label>
      </div>

      <label class="form-control w-full my-1">
        <div class="label py-0 pb-1"><span class="label-text text-[10px] font-bold text-base-content/70">Receipt (Optional)</span></div>
        <input type="file" name="sale_image" accept="image/*" class="file-input file-input-bordered file-input-xs w-full" />
      </label>

      <div class="modal-action m-0 mt-4 pt-4 border-t border-base-200">
        <button type="button" class="btn btn-sm mr-2" onclick="window.record_sale_modal.close()">Cancel</button>
        <button type="submit" class="btn btn-sm btn-primary shadow-lg">Process Bulk Sale</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  function switchSaleMode(mode) {
      if (mode === 'single') {
          document.getElementById('tab_sale_single').classList.add('tab-active', 'text-base-content');
          document.getElementById('tab_sale_single').classList.remove('text-base-content/60');
          document.getElementById('tab_sale_multi').classList.remove('tab-active', 'text-base-content');
          document.getElementById('tab_sale_multi').classList.add('text-base-content/60');
          document.getElementById('sale_single_form').classList.remove('hidden');
          document.getElementById('sale_multi_form').classList.add('hidden');
      } else {
          document.getElementById('tab_sale_multi').classList.add('tab-active', 'text-base-content');
          document.getElementById('tab_sale_multi').classList.remove('text-base-content/60');
          document.getElementById('tab_sale_single').classList.remove('tab-active', 'text-base-content');
          document.getElementById('tab_sale_single').classList.add('text-base-content/60');
          document.getElementById('sale_multi_form').classList.remove('hidden');
          document.getElementById('sale_single_form').classList.add('hidden');
          
          if(document.getElementById('sale_multi_container').children.length === 0) {
              addBulkSaleRow();
          }
      }
  }

  function addBulkSaleRow() {
      const container = document.getElementById('sale_multi_container');
      const idx = container.children.length;
      const html = `
        <div class="flex gap-2 items-center border border-base-300 p-2 rounded-lg bg-base-200/50 relative">
          ${idx > 0 ? `<button type="button" class="btn btn-xs btn-circle btn-ghost absolute -top-2 -right-2 bg-base-100 border border-base-300 text-error shadow-sm z-50" onclick="this.parentElement.remove(); updateBulkSaleTotal();">✕</button>` : ``}
          <label class="form-control flex-1">
            <div class="label py-0 pb-1"><span class="label-text text-[10px] font-bold">Select Item</span></div>
            <select name="item_id[]" class="select select-bordered select-xs w-full" onchange="const p = this.options[this.selectedIndex].dataset.price; this.closest('.flex').querySelector('.bulk-row-price').value = p || 0; updateBulkSaleTotal();" required>
              <option value="" disabled selected>Select from inventory...</option>
              <% if(typeof inventory !== 'undefined') { inventory.forEach(i => { let stock = i.lots.reduce((a,b)=>a+b.qty,0); if(stock > 0) { %><option value="<%= i.id %>" data-price="<%= i.market_price !== null ? i.market_price.toFixed(2) : '0' %>"><%= i.name %> (<%= i.set %>)</option><% }}) } %>
            </select>
          </label>
          <label class="form-control w-20">
            <div class="label py-0 pb-1"><span class="label-text text-[10px] font-bold">Unit Price</span></div>
            <input type="number" step="0.01" name="row_price[]" value="0.00" class="input input-bordered input-xs w-full text-center bulk-row-price" oninput="updateBulkSaleTotal()" required />
          </label>
          <label class="form-control w-16">
            <div class="label py-0 pb-1"><span class="label-text text-[10px] font-bold">Qty</span></div>
            <input type="number" name="qty[]" value="1" min="1" class="input input-bordered input-xs w-full font-mono text-center bulk-row-qty" oninput="updateBulkSaleTotal()" required />
          </label>
        </div>
      `;
      container.insertAdjacentHTML('beforeend', html);
  }

  function updateBulkSaleTotal() {
      let total = 0;
      const prices = document.querySelectorAll('.bulk-row-price');
      const qtys = document.querySelectorAll('.bulk-row-qty');
      for(let i=0; i<prices.length; i++) {
          total += (parseFloat(prices[i].value) || 0) * (parseInt(qtys[i].value) || 0);
      }
      document.getElementById('bulk_sale_gross').value = total.toFixed(2);
  }

  window.appExchangeRates = { CAD: 1.35, CNY: 7.20, HKD: 7.80 };
  
  function toggleInlineConverter(prefix, targetId) {
      const toggle = document.getElementById(prefix + '_currency_toggle').checked;
      const convDiv = document.getElementById(prefix + '_inline_conv');
      const targetInput = document.getElementById(targetId);
      
      if (toggle) {
          convDiv.classList.remove('hidden');
          targetInput.readOnly = true;
          targetInput.classList.add('bg-base-200');
          calcInlineConversion(prefix, targetId);
      } else {
          convDiv.classList.add('hidden');
          targetInput.readOnly = false;
          targetInput.classList.remove('bg-base-200');
      }
  }
  
  function calcInlineConversion(prefix, targetId) {
      const curr = document.getElementById(prefix + '_conv_curr').value;
      const amt = parseFloat(document.getElementById(prefix + '_conv_amt').value) || 0;
      const targetInput = document.getElementById(targetId);
      
      if (!amt) {
          targetInput.value = '';
          return;
      }
      
      let cadValue = 0;
      if (curr === 'USD') cadValue = amt * window.appExchangeRates.CAD;
      if (curr === 'CNY') cadValue = (amt / window.appExchangeRates.CNY) * window.appExchangeRates.CAD;
      if (curr === 'HKD') cadValue = (amt / window.appExchangeRates.HKD) * window.appExchangeRates.CAD;
      
      // Round UP to 1 decimal place ("1 sig fig" relative to cents)
      cadValue = Math.ceil(cadValue * 10) / 10;
      
      targetInput.value = cadValue.toFixed(2);
  }

  window.addEventListener('DOMContentLoaded', async () => {
    try {
      const res = await fetch('/api/exchange-rate');
      const data = await res.json();
      if(data.CAD) {
        window.appExchangeRates = data;
        
        const erCad = document.getElementById('er-cad');
        const erCny = document.getElementById('er-cny');
        const erHkd = document.getElementById('er-hkd');
        
        if (erCad) erCad.innerHTML = '<span class="text-[10px] opacity-60 block leading-none">USD/CAD</span><span class="font-bold text-success text-xs leading-none">' + data.CAD.toFixed(2) + '</span>';
        if (erCny) erCny.innerHTML = '<span class="text-[10px] opacity-60 block leading-none">RMB/CAD</span><span class="font-bold text-warning text-xs leading-none">' + (data.CNY ? (data.CAD / data.CNY).toFixed(3) : 'N/A') + '</span>';
        if (erHkd) erHkd.innerHTML = '<span class="text-[10px] opacity-60 block leading-none">HKD/CAD</span><span class="font-bold text-info text-xs leading-none">' + (data.HKD ? (data.CAD / data.HKD).toFixed(3) : 'N/A') + '</span>';
      }
    } catch(e) {
      const cont = document.getElementById('exchange-rate-container');
      if (cont) cont.innerHTML = '<span class="text-xs opacity-50 w-full text-center py-2">Rates Unavailable</span>';
    }
  });

  // Dynamic Trade Rows
  let tradeCurrentCardsMap = {};
  let tradeSearchTimeouts = {};

  function addTradeGivingRow() {
      const container = document.getElementById('trade_giving_container');
      const idx = container.children.length;
      const html = `
        <div class="trade-giving-row border border-base-200 p-2 rounded-xl relative">
          ${idx > 0 ? `<button type="button" class="btn btn-xs btn-circle btn-ghost absolute -top-2 -right-2 bg-base-100 border border-base-300 text-error shadow-sm z-50" onclick="this.parentElement.remove(); updateTradeVal();">✕</button>` : ``}
          <label class="form-control w-full">
            <div class="label pt-0 pb-1"><span class="label-text text-xs">Item Giving</span></div>
            <select name="giving_item_id[]" class="trade-giving-select select select-bordered select-sm w-full" onchange="updateTradeVal(this)" required>
              <option value="" disabled selected>Select from inventory...</option>
              <% if(typeof inventory !== 'undefined') { inventory.forEach(i => { let stock = i.lots.reduce((a,b)=>a+b.qty,0); if(stock > 0) { %><option value="<%= i.id %>" data-price="<%= i.market_price || 0 %>"><%= i.name %> (<%= i.set %>) - Est. $<%= i.market_price ? i.market_price.toFixed(2) : '0.00' %></option><% }}) } %>
            </select>
          </label>
          <div class="flex gap-2 mt-2">
              <label class="form-control w-1/2">
                <div class="label py-0 pb-1"><span class="label-text text-[10px]">Unit Market Price</span></div>
                <input type="number" step="0.01" name="giving_price_override[]" value="0.00" class="trade-giving-price input input-bordered input-sm w-full text-base-content/80" oninput="updateTradeVal()" />
              </label>
              <label class="form-control w-1/2">
                <div class="label py-0 pb-1"><span class="label-text text-[10px]">Qty Giving</span></div>
                <input type="number" name="giving_qty[]" value="1" min="1" class="trade-giving-qty input input-bordered input-sm w-full" oninput="updateTradeVal()" required />
              </label>
          </div>
        </div>
      `;
      container.insertAdjacentHTML('beforeend', html);
  }

  function addTradeReceivingRow() {
      const container = document.getElementById('trade_receiving_container');
      const idx = Date.now() + Math.floor(Math.random() * 1000); // Unique ID
      const html = `
        <div class="trade-receiving-row border border-base-200 p-2 rounded-xl relative" data-row="${idx}">
          ${container.children.length > 0 ? `<button type="button" class="btn btn-xs btn-circle btn-ghost absolute -top-2 -right-2 bg-base-100 border border-base-300 text-error shadow-sm z-50" onclick="this.parentElement.remove(); updateTradeVal();">✕</button>` : ``}
          <label class="form-control w-full relative z-[80]">
            <div class="label pt-0 pb-1"><span class="label-text text-xs w-full flex justify-between items-center">Item Receiving <select class="trade-data-source select select-bordered select-xs ml-2 border-base-300 bg-base-200"><option value="tcgplayer">TCGPlayer</option><option value="pricecharting">PriceChart</option><option value="manual">Manual/DB</option></select></span></div>
            <input type="text" name="receiving_name[]" placeholder="Search API..." class="trade-search-input input input-bordered input-sm w-full" autocomplete="off" required />
            <ul class="trade-search-results absolute top-[60px] left-0 w-full bg-base-100 shadow-2xl rounded-lg max-h-60 overflow-y-auto hidden border border-base-300 z-[100] mt-1"></ul>
            
            <div class="trade-link-container mt-1 text-[11px] hidden text-right w-full">
              <a href="#" target="_blank" class="trade-reference-link link link-primary opacity-80 hover:opacity-100">Verify Market Link &UpperRightArrow;</a>
            </div>

            <input type="hidden" class="trade-receiving-set" name="receiving_set[]" value="">
            <input type="hidden" class="trade-receiving-image" name="receiving_image[]" value="">
            <input type="hidden" class="trade-receiving-tcgplayer" name="receiving_tcgplayer[]" value="">
          </label>
          <div class="flex gap-2 mt-2">
              <label class="form-control w-1/2">
                <div class="label py-0 pb-1"><span class="label-text text-[10px]">Unit Market Price</span></div>
                <input type="number" step="0.01" name="receiving_price[]" value="0.00" class="trade-receiving-price input input-bordered input-sm w-full" oninput="updateTradeVal()" required />
              </label>
              <label class="form-control w-1/2">
                <div class="label py-0 pb-1"><span class="label-text text-[10px]">Qty Receiving</span></div>
                <input type="number" name="receiving_qty[]" value="1" min="1" class="trade-receiving-qty input input-bordered input-sm w-full" oninput="updateTradeVal()" required />
              </label>
          </div>
        </div>
      `;
      container.insertAdjacentHTML('beforeend', html);
  }

  document.addEventListener('input', (e) => {
      if(!e.target.classList.contains('trade-search-input')) return;
      
      const row = e.target.closest('.trade-receiving-row');
      const rowId = row.dataset.row;
      const source = row.querySelector('.trade-data-source').value;
      const resultsUl = row.querySelector('.trade-search-results');
      
      clearTimeout(tradeSearchTimeouts[rowId]);
      const q = e.target.value.trim();
      
      if (q.length < 3 || source === 'manual') { resultsUl.classList.add('hidden'); return; }
      
      tradeSearchTimeouts[rowId] = setTimeout(async () => {
          const endpoint = source === 'pricecharting' ? '/api/search/sealed?q=' : '/api/search?q=';
          const res = await fetch(endpoint + encodeURIComponent(q));
          const data = await res.json();
          
          if (source === 'pricecharting' && Array.isArray(data)) {
             tradeCurrentCardsMap[rowId] = data;
             resultsUl.innerHTML = data.map((p, idx) => {
                return '<li class="p-3 hover:bg-base-200 cursor-pointer flex gap-3" onclick="selectTradeCard('+idx+', \''+rowId+'\', \'pricecharting\')">' +
                  '<div class="flex-1 text-sm leading-tight font-medium">' + p.productName + ' <span class="opacity-50 text-xs block">' + (p.consoleName||'Unk') + '</span></div>' +
                  '<div class="font-bold text-success whitespace-nowrap">$' + Number(p.price).toFixed(2) + '</div>' +
                '</li>';
             }).join('');
             resultsUl.classList.remove('hidden');
          } else if (data.data) {
             tradeCurrentCardsMap[rowId] = data.data;
             resultsUl.innerHTML = data.data.map((card, idx) => {
                const price = card.tcgplayer?.prices?.normal?.market || card.tcgplayer?.prices?.holofoil?.market || 0;
                return '<li class="p-3 hover:bg-base-200 cursor-pointer flex gap-3" onclick="selectTradeCard('+idx+', \''+rowId+'\', \'tcgplayer\')">' +
                  '<img src="' + (card.images?.small || '') + '" class="w-6 h-8 object-contain bg-base-300 rounded-sm" />' +
                  '<div class="flex-1 text-sm leading-tight font-medium">' + card.name + ' <span class="opacity-50 text-xs block">' + (card.set?.name||'Unk') + '</span></div>' +
                  '<div class="font-bold text-success whitespace-nowrap">$' + Number(price).toFixed(2) + '</div>' +
                '</li>';
             }).join('');
             resultsUl.classList.remove('hidden');
          }
      }, 500);
  });

  function selectTradeCard(idx, rowId, source) {
      const row = document.querySelector(`.trade-receiving-row[data-row="${rowId}"]`);
      if(!row) return;
      
      const cards = tradeCurrentCardsMap[rowId];
      if (source === 'pricecharting') {
          const item = cards[idx];
          row.querySelector('.trade-search-input').value = item.productName || '';
          row.querySelector('.trade-receiving-price').value = item.price.toFixed(2);
          row.querySelector('.trade-receiving-set').value = item.consoleName || 'Sealed';
          row.querySelector('.trade-receiving-image').value = '';
          row.querySelector('.trade-receiving-tcgplayer').value = item.url || '';
          
          if(item.url) {
            row.querySelector('.trade-link-container').classList.remove('hidden');
            row.querySelector('.trade-reference-link').href = item.url;
          }
      } else {
          const card = cards[idx];
          const price = card.tcgplayer?.prices?.normal?.market || card.tcgplayer?.prices?.holofoil?.market || 0;
          row.querySelector('.trade-search-input').value = card.name || '';
          row.querySelector('.trade-receiving-price').value = price.toFixed(2);
          row.querySelector('.trade-receiving-set').value = card.set?.name || 'Unknown';
          row.querySelector('.trade-receiving-image').value = card.images?.small || '';
          row.querySelector('.trade-receiving-tcgplayer').value = card.tcgplayer?.url || '';
          
          if (card.tcgplayer?.url) {
              row.querySelector('.trade-link-container').classList.remove('hidden');
              row.querySelector('.trade-reference-link').href = card.tcgplayer.url;
          }
      }
      row.querySelector('.trade-search-results').classList.add('hidden');
      updateTradeVal();
  }

  function updateTradeVal(selectElementChanged = null) {
      if (selectElementChanged && selectElementChanged.classList.contains('trade-giving-select')) {
          const row = selectElementChanged.closest('.trade-giving-row');
          if(row) {
             const priceInput = row.querySelector('.trade-giving-price');
             priceInput.value = parseFloat(selectElementChanged.options[selectElementChanged.selectedIndex]?.dataset.price || 0).toFixed(2);
          }
      }

      let givingTotal = 0;
      document.querySelectorAll('.trade-giving-row').forEach(row => {
          const p = parseFloat(row.querySelector('.trade-giving-price').value || 0);
          const q = parseInt(row.querySelector('.trade-giving-qty').value || 1);
          givingTotal += p * q;
      });
      const cGiv = parseFloat(document.getElementById('trade_cash_given')?.value || 0);
      document.getElementById('trade_giving_total').innerText = '$' + (givingTotal + cGiv).toFixed(2);
      
      let receivingTotal = 0;
      document.querySelectorAll('.trade-receiving-row').forEach(row => {
          const p = parseFloat(row.querySelector('.trade-receiving-price').value || 0);
          const q = parseInt(row.querySelector('.trade-receiving-qty').value || 1);
          receivingTotal += p * q;
      });
      const cRec = parseFloat(document.getElementById('trade_cash_received')?.value || 0);
      document.getElementById('trade_receiving_total').innerText = '$' + (receivingTotal + cRec).toFixed(2);
  }

  // Initialize trade rows on load
  window.addEventListener('DOMContentLoaded', () => {
    if(document.getElementById('trade_giving_container')) {
        addTradeGivingRow();
        addTradeReceivingRow();
    }
  });
  let bulkCart = [];
  
  function switchAddMode(mode) {
      if(mode === 'single') {
          document.getElementById('tab_single_item').classList.add('tab-active', 'text-primary-content');
          document.getElementById('tab_single_item').classList.remove('text-primary-content/70');
          document.getElementById('tab_bulk_item').classList.remove('tab-active', 'text-primary-content');
          document.getElementById('tab_bulk_item').classList.add('text-primary-content/70');
          document.getElementById('single_add_form').classList.remove('hidden');
          document.getElementById('bulk_add_form').classList.add('hidden');
          document.getElementById('bulk_add_form').classList.remove('flex');
      } else {
          document.getElementById('tab_bulk_item').classList.add('tab-active', 'text-primary-content');
          document.getElementById('tab_bulk_item').classList.remove('text-primary-content/70');
          document.getElementById('tab_single_item').classList.remove('tab-active', 'text-primary-content');
          document.getElementById('tab_single_item').classList.add('text-primary-content/70');
          document.getElementById('bulk_add_form').classList.remove('hidden');
          document.getElementById('bulk_add_form').classList.add('flex');
          document.getElementById('single_add_form').classList.add('hidden');
      }
  }

  const bulkSearchInput = document.getElementById('bulk_search_input');
  const bulkSearchResults = document.getElementById('bulk_search_results');
  let bulkCurrentCards = [];
  let bulkSearchTimeout;

  bulkSearchInput?.addEventListener('input', (e) => {
    clearTimeout(bulkSearchTimeout);
    const q = e.target.value.trim();
    const source = document.getElementById('bulk_data_source').value;
    if (q.length < 3) { bulkSearchResults.classList.add('hidden'); return; }
    
    bulkSearchTimeout = setTimeout(async () => {
      const endpoint = source === 'pricecharting' ? '/api/search/sealed?q=' : '/api/search?q=';
      const res = await fetch(endpoint + encodeURIComponent(q));
      const data = await res.json();
      
      if (source === 'pricecharting' && Array.isArray(data)) {
         bulkCurrentCards = data;
         bulkSearchResults.innerHTML = bulkCurrentCards.map((p, idx) => {
            return '<li class="p-3 hover:bg-base-200 cursor-pointer flex gap-3 items-center border-b border-base-200/50" onclick="addToBulkCart('+idx+', \'pricecharting\')">' +
              '<div class="flex-1 text-sm leading-tight font-bold">' + p.productName + ' <span class="opacity-50 text-[10px] block font-normal">' + (p.consoleName||'Unk') + '</span></div>' +
              '<div class="font-bold text-success whitespace-nowrap">$' + Number(p.price).toFixed(2) + '</div>' +
            '</li>';
         }).join('');
         bulkSearchResults.classList.remove('hidden');
      } else if (data.data) {
        bulkCurrentCards = data.data;
        bulkSearchResults.innerHTML = bulkCurrentCards.map((card, idx) => {
            const price = card.tcgplayer?.prices?.normal?.market || card.tcgplayer?.prices?.holofoil?.market || 0;
            return '<li class="p-3 hover:bg-base-200 cursor-pointer flex gap-3 items-center border-b border-base-200/50" onclick="addToBulkCart('+idx+', \'tcgplayer\')">' +
              '<img src="' + (card.images?.small || '') + '" class="w-6 h-8 object-contain bg-base-300 rounded-sm" />' +
              '<div class="flex-1 text-sm leading-tight font-bold">' + card.name + ' <span class="opacity-50 text-[10px] block font-normal">' + (card.set?.name||'Unk') + '</span></div>' +
              '<div class="font-bold text-success whitespace-nowrap text-xs">$' + Number(price).toFixed(2) + '</div>' +
            '</li>';
        }).join('');
        bulkSearchResults.classList.remove('hidden');
      }
    }, 500);
  });

  function addToBulkCart(idx, source) {
      const isPC = source === 'pricecharting';
      const raw = bulkCurrentCards[idx];
      const price = isPC ? raw.price : (raw.tcgplayer?.prices?.normal?.market || raw.tcgplayer?.prices?.holofoil?.market || raw.tcgplayer?.prices?.reverseHolofoil?.market || 0);
      
      bulkCart.push({
          id: Date.now(),
          name: isPC ? raw.productName : raw.name,
          set_name: isPC ? (raw.consoleName || 'Sealed') : (raw.set?.name || 'Unknown'),
          image: isPC ? '' : (raw.images?.small || ''),
          tcgplayer_url: isPC ? (raw.url || '') : (raw.tcgplayer?.url || ''),
          market_price: parseFloat(price || 0),
          category: isPC ? 'Sealed' : 'Singles',
          data_source: source,
          condition: isPC ? 'Sealed' : 'Near Mint',
          qty: 1,
          unit_cog: 0
      });
      
      bulkSearchInput.value = '';
      bulkSearchResults.classList.add('hidden');
      renderBulkCart();
  }
  
  function renderBulkCart() {
      const tbody = document.getElementById('bulk_cart_body');
      if(bulkCart.length === 0) {
          tbody.innerHTML = '<tr id="bulk_empty_state"><td colspan="5" class="text-center py-10 opacity-50 italic text-xs">Waiting for payload connection. Search above to array cards.</td></tr>';
          return;
      }
      
      tbody.innerHTML = bulkCart.map(c => `
        <tr class="hover border-b border-base-200">
            <td class="pl-4">
              <div class="font-bold leading-tight text-xs">${c.name}</div>
              <div class="text-[10px] opacity-70">${c.set_name}</div>
            </td>
            <td class="hidden md:table-cell">
                <select class="select select-bordered select-xs w-full text-[10px]" onchange="updateCartItem(${c.id}, 'condition', this.value)">
                    <option ${c.condition==='Near Mint'?'selected':''}>Near Mint</option>
                    <option ${c.condition==='Lightly Played'?'selected':''}>Lightly Played</option>
                    <option ${c.condition==='Sealed'?'selected':''}>Sealed</option>
                </select>
            </td>
            <td>
                <input type="number" min="1" value="${c.qty}" class="input input-bordered input-xs w-full font-mono text-center" oninput="updateCartItem(${c.id}, 'qty', this.value)" />
            </td>
            <td>
                <input type="number" step="0.01" value="${c.unit_cog}" class="input input-bordered input-xs w-full font-mono text-right" oninput="updateCartItem(${c.id}, 'unit_cog', this.value)" />
            </td>
            <td class="text-center border-l border-base-200 bg-error/5 cursor-pointer hover:bg-error/20 transition-colors" onclick="removeBulkCart(${c.id})">
                <span class="text-error font-bold text-center w-full block">✕</span>
            </td>
        </tr>
      `).join('');
  }
  
  function updateCartItem(id, field, val) {
      const item = bulkCart.find(c => c.id === id);
      if(item) {
          if(field === 'qty') item.qty = Math.max(1, parseInt(val)||1);
          if(field === 'unit_cog') item.unit_cog = parseFloat(val)||0;
          if(field === 'condition') item.condition = val;
      }
  }
  
  function removeBulkCart(id) {
      bulkCart = bulkCart.filter(c => c.id !== id);
      renderBulkCart();
  }
  
  function submitBulkShipment() {
      if(bulkCart.length === 0) return alert("Add items to the shipment manifest first!");
      document.getElementById('bulk_payload_data').value = JSON.stringify(bulkCart);
      document.getElementById('bulk_add_form').submit();
  }
</script>
</body>
</html>
