<script>
  const searchInput = document.getElementById('item_search_input');
  const searchResults = document.getElementById('search_results');
  const dataSourceSelect = document.getElementById('data_source_select');
  let currentCards = [];
  let searchTimeout;

  searchInput.addEventListener('input', (e) => {
    clearTimeout(searchTimeout);
    
    if (dataSourceSelect.value === 'manual') {
      searchResults.classList.add('hidden');
      return;
    }

    const q = e.target.value.trim();
    if (q.length < 3) {
      searchResults.classList.add('hidden');
      return;
    }
    
    // Choose the API endpoint based on data source select
    const isPriceCharting = dataSourceSelect.value === 'pricecharting';
    const endpoint = isPriceCharting ? '/api/search/sealed' : '/api/search';

    searchTimeout = setTimeout(async () => {
      try {
        const res = await fetch(endpoint + '?q=' + encodeURIComponent(q));
        const data = await res.json();
        
        if (data.data && data.data.length > 0) {
          currentCards = data.data;
          searchResults.innerHTML = currentCards.map((card, idx) => {
            const price = card.tcgplayer?.prices?.normal?.market || card.tcgplayer?.prices?.holofoil?.market || card.tcgplayer?.prices?.reverseHolofoil?.market || 0;
            return '<li class="p-3 hover:bg-base-200 cursor-pointer flex items-center gap-3 border-b border-base-200/50 last:border-0" data-idx="' + idx + '">' +
              '<img src="' + (card.images?.small || '') + '" class="w-8 h-12 object-contain bg-base-300 rounded-sm" />' +
              '<div class="flex-1">' +
                '<div class="font-bold text-sm leading-tight">' + card.name + '</div>' +
                '<div class="text-[10px] opacity-70">' + card.set?.name + '</div>' +
              '</div>' +
              '<div class="text-xs font-bold text-success">' + (price ? '$'+price.toFixed(2) : 'N/A') + '</div>' +
            '</li>';
          }).join('');
          
          searchResults.querySelectorAll('li').forEach(li => {
            li.addEventListener('click', function() {
              const card = currentCards[this.getAttribute('data-idx')];
              const price = card.tcgplayer?.prices?.normal?.market || card.tcgplayer?.prices?.holofoil?.market || card.tcgplayer?.prices?.reverseHolofoil?.market || 0;
              searchInput.value = card.name;
              document.getElementById('api_set_name').value = card.set?.name || '';
              document.getElementById('api_image_url').value = card.images?.small || '';
              document.getElementById('api_tcgplayer_url').value = card.tcgplayer?.url || '';
              if(price) document.getElementById('manual_market_price').value = price;
              searchResults.classList.add('hidden');
            });
          });
          
          searchResults.classList.remove('hidden');
        } else {
          searchResults.innerHTML = '<li class="p-3 text-sm opacity-50 text-center">No results found</li>';
          searchResults.classList.remove('hidden');
        }
      } catch (err) {
        console.error(err);
      }
    }, 500);
  });

  document.addEventListener('click', (e) => {
    if(!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
      searchResults.classList.add('hidden');
    }
  });
</script>

