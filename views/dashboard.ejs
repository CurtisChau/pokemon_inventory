<%- include('partials/header') %>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(150, 150, 150, 0.2); border-radius: 10px; }
</style>

<main class="flex-1 p-4 lg:p-6 w-full max-w-[1600px] mx-auto overflow-x-hidden">
  <div class="flex flex-col gap-6">
    <!-- TOP SECTION -->
    <div class="flex flex-col gap-6 w-full">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight bg-gradient-to-br from-base-content to-base-content/60 bg-clip-text text-transparent drop-shadow-sm">Dashboard Overview</h1>
          <div class="flex items-center gap-1.5 mt-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span id="est-clock" class="text-xs font-mono text-base-content/50"></span>
          </div>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <button id="syncBtn" onclick="startSync()" class="btn btn-primary btn-sm rounded-full px-5 shadow-lg shadow-primary/30 flex items-center gap-1 hover:scale-105 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" /></svg>
            Sync Prices
          </button>
        </div>
      </div>

      <%
        const _person = typeof selectedPerson !== 'undefined' ? selectedPerson : 'all';
        const _sd = typeof startDate !== 'undefined' ? startDate : '';
        const _ed = typeof endDate   !== 'undefined' ? endDate   : '';
        let _rangeLabel;
        if (range === 'custom' && _sd) {
          _rangeLabel = _sd === _ed || !_ed ? _sd : _sd + ' → ' + _ed;
        } else {
          _rangeLabel = range === 'today' ? 'Today' : range === '7' ? 'Last 7 Days' : range === '30' ? 'Last 30 Days' : range === '90' ? 'Last 90 Days' : 'All Time';
        }
        const _baseUrl    = '/?person=' + _person + '&range=';
        const _rangeParams = 'range=' + range + (_sd ? '&start_date=' + _sd : '') + (_ed ? '&end_date=' + _ed : '');
      %>
      <!-- Period + Seller Selectors -->
      <div class="flex flex-col gap-2">
        <!-- Period row -->
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-[10px] font-bold text-base-content/50 uppercase tracking-wider w-10">Period</span>
          <div class="join">
            <a href="<%= _baseUrl %>today" class="join-item btn btn-xs <%= range === 'today'  ? 'btn-primary' : 'btn-ghost border border-base-300' %>">Today</a>
            <a href="<%= _baseUrl %>7"     class="join-item btn btn-xs <%= range === '7'      ? 'btn-primary' : 'btn-ghost border border-base-300' %>">7D</a>
            <a href="<%= _baseUrl %>30"    class="join-item btn btn-xs <%= range === '30' || (!range && range !== 'custom') ? 'btn-primary' : 'btn-ghost border border-base-300' %>">30D</a>
            <a href="<%= _baseUrl %>90"    class="join-item btn btn-xs <%= range === '90'     ? 'btn-primary' : 'btn-ghost border border-base-300' %>">90D</a>
            <a href="<%= _baseUrl %>all"   class="join-item btn btn-xs <%= range === 'all'    ? 'btn-primary' : 'btn-ghost border border-base-300' %>">All Time</a>
            <button type="button" onclick="document.getElementById('custom-range-picker').classList.toggle('hidden')"
              class="join-item btn btn-xs <%= range === 'custom' ? 'btn-secondary' : 'btn-ghost border border-base-300' %>">
              Custom ▾
            </button>
          </div>
        </div>

        <!-- Seller row -->
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-[10px] font-bold text-base-content/50 uppercase tracking-wider w-10">Seller</span>
          <div class="join">
            <a href="/?person=all&<%= _rangeParams %>" class="join-item btn btn-xs <%= _person === 'all' ? 'btn-secondary' : 'btn-ghost border border-base-300' %>">Everyone</a>
            <% if(typeof persons !== 'undefined') { persons.forEach(p => { %>
            <a href="/?person=<%= p %>&<%= _rangeParams %>" class="join-item btn btn-xs <%= _person === p ? 'btn-secondary' : 'btn-ghost border border-base-300' %>"><%= p %></a>
            <% }) } %>
          </div>
        </div>

        <!-- Custom date picker -->
        <form method="GET" action="/" id="custom-range-picker" class="<%= range === 'custom' ? '' : 'hidden' %> flex items-end gap-2 flex-wrap bg-base-100 border border-base-300 rounded-xl px-3 py-2">
          <input type="hidden" name="person" value="<%= _person %>" />
          <input type="hidden" name="range" value="custom" />
          <label class="flex flex-col gap-1">
            <span class="text-[9px] font-bold uppercase text-base-content/50">From</span>
            <input type="date" name="start_date" value="<%= _sd %>" class="input input-xs input-bordered w-36" required />
          </label>
          <label class="flex flex-col gap-1">
            <span class="text-[9px] font-bold uppercase text-base-content/50">To (leave blank = today)</span>
            <input type="date" name="end_date" value="<%= _ed %>" class="input input-xs input-bordered w-36" />
          </label>
          <button type="submit" class="btn btn-xs btn-secondary">Apply</button>
          <a href="/?person=all&range=30" class="btn btn-xs btn-ghost">Clear</a>
        </form>
      </div>

      <!-- Stats Carousel/Grid -->
      <% 
        const totalCogs = inventory.reduce((sum, item) => sum + item.lots.reduce((q, l) => q + (l.qty * l.cog), 0), 0);
        const strictShippingTotal = (typeof totalShipping !== 'undefined') ? totalShipping : 0;
        const margin = totalValue - totalCogs;
        const realizedProfit = sales.reduce((sum, s) => sum + (s.total_price - (s.cogs_sold || 0)), 0);
      %>
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-3">
        <div class="card bg-base-100 shadow-sm border border-base-200/50 hover:border-primary/40 transition-colors">
          <div class="card-body p-4 lg:p-5 flex flex-col justify-center">
            <h2 class="card-title text-[10px] font-bold text-base-content/60 uppercase tracking-wider leading-none">Total Value</h2>
            <p class="text-2xl font-black mt-2 text-primary shadow-primary/10">$<%= totalValue.toFixed(2) %></p>
          </div>
        </div>
        <div class="card bg-base-100 shadow-sm border border-base-200/50 hover:border-secondary/40 transition-colors">
          <div class="card-body p-4 lg:p-5 flex flex-col justify-center">
            <h2 class="card-title text-[10px] font-bold text-base-content/60 uppercase tracking-wider leading-none">Net Sales</h2>
            <p class="text-2xl font-black mt-2 text-secondary shadow-secondary/10">$<%= sales.reduce((a, b) => a + b.total_price, 0).toFixed(2) %></p>
            <span class="text-[9px] text-base-content/40 mt-1"><%= _rangeLabel %><%= _person !== 'all' ? ' · ' + _person : '' %></span>
          </div>
        </div>

        <!-- Highlighted Profit Card -->
        <div class="card bg-base-100 shadow-sm border border-success/30 relative overflow-hidden outline outline-action/30 col-span-2 lg:col-span-1">
          <div class="absolute -right-4 -top-4 bg-success/20 w-16 h-16 rounded-full blur-xl"></div>
          <div class="card-body p-4 lg:p-5 flex flex-col justify-center z-10">
            <h2 class="card-title text-[11px] font-black uppercase tracking-wider text-success flex items-center gap-1 leading-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Realized Profit
            </h2>
            <p class="text-3xl font-black mt-2 text-success drop-shadow-sm">$<%= realizedProfit.toFixed(2) %></p>
            <span class="text-[9px] text-success/40 mt-1"><%= _rangeLabel %><%= _person !== 'all' ? ' · ' + _person : '' %></span>
          </div>
        </div>

        <div class="card bg-base-100 shadow-sm border border-base-200/50 hover:bg-base-200/20 transition-colors">
          <div class="card-body p-4 lg:p-5 flex flex-col justify-center">
            <h2 class="card-title text-[10px] font-bold text-base-content/60 uppercase tracking-wider leading-none" title="If all current inventory is sold at market price">Est. Margin</h2>
            <p class="text-xl font-bold mt-2 text-base-content/80">$<%= margin.toFixed(2) %></p>
          </div>
        </div>
        <div class="card bg-base-100 shadow-sm border border-base-200/50 hover:bg-base-200/20 transition-colors">
          <div class="card-body p-4 lg:p-5 flex flex-col justify-center">
            <h2 class="card-title text-[10px] font-bold text-base-content/60 uppercase tracking-wider leading-none">Shipping Cost</h2>
            <p class="text-xl font-bold mt-2 text-warning">$<%= strictShippingTotal.toFixed(2) %></p>
          </div>
        </div>
      </div>

      <!-- Charts Section -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6">
        <div class="card bg-base-100 shadow-sm border border-base-200/50 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent pointer-events-none"></div>
          <div class="card-body p-4 lg:p-6 z-10">
            <h2 class="card-title text-sm font-bold text-base-content/70 uppercase tracking-wider mb-2">Sales Revenue Trend <span class="badge badge-xs badge-ghost ml-1 font-normal normal-case"><%= _rangeLabel %></span></h2>
            <div class="h-64 w-full relative">
              <canvas id="salesChart"></canvas>
            </div>
          </div>
        </div>
        <div class="card bg-base-100 shadow-sm border border-base-200/50">
          <div class="card-body p-4 lg:p-6 flex flex-col items-center">
            <h2 class="card-title text-sm font-bold text-base-content/70 uppercase tracking-wider mb-2 w-full text-left">Inventory by Category</h2>
            <div class="h-64 w-full relative flex items-center justify-center">
              <canvas id="categoryChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <h2 class="text-xl font-bold mt-2 tracking-tight">Quick Actions</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
        <button onclick="document.getElementById('record_sale_modal').showModal()" class="btn h-24 flex flex-col gap-2 justify-center border border-base-300 hover:border-primary/50 hover:bg-primary/5 transition-all shadow-sm rounded-2xl group">
          <div class="p-2 bg-base-200 rounded-full group-hover:bg-primary group-hover:text-primary-content transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          </div>
          <span class="font-semibold text-xs text-base-content/70 group-hover:text-base-content">Record Sale</span>
        </button>
        <button onclick="document.getElementById('add_item_modal').showModal(); switchAddMode('bulk');" class="btn h-24 flex flex-col gap-2 justify-center border border-base-300 hover:border-secondary/50 hover:bg-secondary/5 transition-all shadow-sm rounded-2xl group">
          <div class="p-2 bg-base-200 rounded-full group-hover:bg-secondary group-hover:text-secondary-content transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <span class="font-semibold text-xs text-base-content/70 group-hover:text-base-content">Bulk Import</span>
        </button>
        <button onclick="document.getElementById('record_trade_modal').showModal()" class="btn h-24 flex flex-col gap-2 justify-center border border-base-300 hover:border-accent/50 hover:bg-accent/5 transition-all shadow-sm rounded-2xl group">
          <div class="p-2 bg-base-200 rounded-full group-hover:bg-accent group-hover:text-accent-content transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          </div>
          <span class="font-semibold text-xs text-base-content/70 group-hover:text-base-content">Record Trade</span>
        </button>
        <button onclick="document.getElementById('apply_shipping_modal').showModal()" class="btn h-24 flex flex-col gap-2 justify-center border border-base-300 hover:border-warning/50 hover:bg-warning/5 transition-all shadow-sm rounded-2xl group">
          <div class="p-2 bg-base-200 rounded-full group-hover:bg-warning group-hover:text-warning-content transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4m16 0l-4-4m4 4l-4 4"/></svg>
          </div>
          <span class="font-semibold text-xs text-base-content/70 group-hover:text-base-content">Distribute Freight</span>
        </button>
      </div>

    </div> <!-- Close Top Section -->

    <!-- BOTTOM SECTION: LEDGER -->
    <div class="w-full flex flex-col gap-4 bg-base-200/30 rounded-[2rem] p-4 lg:p-6 border border-base-300/50 shadow-inner mt-4">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-bold tracking-tight flex items-center gap-2">
          <div class="p-2 bg-base-content text-base-100 rounded-xl shadow-md">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          Activity Ledger
        </h2>
      </div>

      <div class="flex flex-col lg:flex-row gap-4">
        <!-- Ledger Filters & Mini Chart (Left Side on Desktop) -->
        <div class="w-full lg:w-1/3 flex flex-col gap-4">
            <div class="bg-base-100 p-3 rounded-2xl border border-base-200 shadow-sm flex flex-col gap-1">
                <span class="text-[10px] font-bold text-base-content/50 uppercase tracking-wider">Active Filters</span>
                <div class="flex flex-wrap gap-1 mt-1">
                  <span class="badge badge-xs badge-ghost border border-base-300"><%= _rangeLabel %></span>
                  <% if(_person !== 'all') { %><span class="badge badge-xs badge-secondary"><%= _person %></span><% } %>
                </div>
            </div>

            <div class="bg-base-100 p-4 rounded-2xl border border-base-200 shadow-sm h-36 relative flex flex-col justify-end overflow-hidden flex-1">
                <h3 class="absolute top-3 left-4 text-[10px] font-bold uppercase tracking-wider text-base-content/50 z-10">Ledger Velocity</h3>
                <canvas id="ledgerChart"></canvas>
            </div>
        </div>

        <!-- Log List (Right Side on Desktop) -->
        <div class="w-full lg:w-2/3 max-h-[500px] overflow-y-auto pr-1 space-y-3 custom-scrollbar">
            <% if(typeof activity !== 'undefined' && activity.length > 0) {
                activity.forEach((act, actIdx) => { %>
            <div class="bg-base-100 p-3 border border-base-200 rounded-2xl shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all relative overflow-hidden group<%= actIdx >= 50 ? ' activity-extra hidden' : '' %>">
                <div class="flex justify-between items-start mb-2">
                <div class="flex items-center gap-2">
                    <% if(act.log_type === 'sale') { %>
                    <div class="w-7 h-7 rounded-lg <%= act.type === 'Trade' ? 'bg-warning/20 text-warning' : 'bg-success/20 text-success' %> flex items-center justify-center font-bold text-xs"><%= act.type === 'Sale' ? 'S' : 'T' %></div>
                    <span class="font-bold text-sm leading-tight max-w-[200px] truncate" title="<%= act.item_name %>"><%= act.item_name %> <span class="opacity-50 text-[10px] ml-0.5">x<%= act.qty %></span></span>
                    <% } else if (act.log_type === 'shipping') { %>
                    <div class="w-7 h-7 rounded-lg bg-error/20 text-error flex items-center justify-center font-bold text-xs"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg></div>
                    <span class="font-bold text-sm leading-tight text-base-content/80">Freight Log</span>
                    <% } %>
                </div>
                <span class="text-[9px] font-medium opacity-50 bg-base-200 px-1.5 py-0.5 rounded-md border border-base-300"><%= new Date(act.date).toLocaleDateString(undefined, {month:'short', day:'numeric'}) %></span>
                </div>
                
                <div class="flex justify-between items-end pl-[36px]">
                <% if(act.log_type === 'sale') { %>
                    <div class="flex items-center gap-2">
                        <span class="text-[10px] bg-secondary/10 text-secondary border border-secondary/20 px-2 py-0.5 rounded flex items-center gap-1 font-semibold max-w-[100px] truncate"><svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg> <%= act.person || 'Unknown' %></span>
                        <% if(act.has_image) { %>
                           <button onclick="openReceiptModal(<%= act.id %>)" class="text-[10px] bg-info/10 text-info border border-info/20 px-2 py-0.5 rounded flex items-center gap-1 font-semibold hover:bg-info hover:text-info-content transition-colors" title="View Proof">🖼️ Image</button>
                        <% } %>
                    </div>
                    <div class="text-right">
                        <div class="font-black text-success leading-none text-base">+$<%= act.total_price.toFixed(2) %></div>
                        <div class="text-[9px] opacity-60 mt-1 font-mono tracking-tighter" title="Cost of Goods Sold">COGS:$<%= (act.cogs_sold||0).toFixed(2) %> | PROFIT:$<%= (act.total_price - (act.cogs_sold||0)).toFixed(2) %></div>
                    </div>
                    <form method="POST" action="/sales/refund" class="absolute inset-y-0 right-0 bg-base-200/95 backdrop-blur-sm px-3 flex items-center justify-center translate-x-[110%] group-hover:translate-x-0 transition-transform duration-300 ease-out border-l border-base-300">
                    <input type="hidden" name="sale_id" value="<%= act.id %>" />
                    <button type="submit" class="btn btn-sm btn-error shadow-sm rounded-xl" onclick="return confirm('Refund transaction and resurrect stock?')">Undo</button>
                    </form>
                <% } else if (act.log_type === 'shipping') { %>
                    <span class="text-[10px] opacity-50">Distrib. Math</span>
                    <div class="text-right">
                        <div class="font-black text-error leading-none text-base">-$<%= (act.cost || 0).toFixed(2) %></div>
                    </div>
                    <form method="POST" action="/shipping/undo" class="absolute inset-y-0 right-0 bg-base-200/95 backdrop-blur-sm px-3 flex items-center justify-center translate-x-[110%] group-hover:translate-x-0 transition-transform duration-300 ease-out border-l border-base-300">
                    <input type="hidden" name="shipping_id" value="<%= act.id %>" />
                    <button type="submit" class="btn btn-sm btn-error shadow-sm rounded-xl" onclick="return confirm('Reverse this overhead tracking?')">Undo</button>
                    </form>
                <% } %>
                </div>
            </div>
            <% })} %>
            <% if(activity.length > 50) { %>
            <button onclick="document.querySelectorAll('.activity-extra').forEach(el=>el.classList.remove('hidden')); this.remove();" class="w-full btn btn-ghost btn-sm mt-2 text-base-content/50 hover:text-base-content border border-dashed border-base-300">
              Show all <%= activity.length %> entries
            </button>
            <% } %>
            <% if(activity.length === 0) { %>
            <div class="text-center py-10 opacity-30 italic text-xs border-2 border-dashed border-base-300 rounded-2xl flex flex-col items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-base-content" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                Quiet here...
            </div>
            <% } %>
        </div>
      </div>
    </div> <!-- Close Ledger Bottom Section -->
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script id="inventory-data" type="application/json"><%- JSON.stringify((inventory || []).map(i => ({ id: i.id, name: i.name, set_name: i.set_name, category: i.category, market_price: i.market_price, lots: i.lots }))) %></script>
<script id="sales-data" type="application/json"><%- JSON.stringify((sales || []).map(s => ({ id: s.id, item_name: s.item_name, qty: s.qty, total_price: s.total_price, type: s.type, date: s.date, person: s.person, cogs_sold: s.cogs_sold }))) %></script>
<script id="activity-data" type="application/json"><%- JSON.stringify((activity || []).map(a => ({ id: a.id, item_name: a.item_name, qty: a.qty, total_price: a.total_price, type: a.type, date: a.date, person: a.person, cogs_sold: a.cogs_sold, cost: a.cost, impacts: a.impacts, log_type: a.log_type, has_image: a.has_image }))) %></script>
<script>
  const inventoryData = JSON.parse(document.getElementById('inventory-data').textContent);
  const salesData = JSON.parse(document.getElementById('sales-data').textContent);
  const activityData = JSON.parse(document.getElementById('activity-data').textContent);
  
  // 1. Sales Trend
  const salesByDate = {};
  salesData.forEach(s => {
      let d = 'Unknown';
      if(s.date) {
          const dt = new Date(s.date);
          if(!isNaN(dt.valueOf())) d = dt.toISOString().split('T')[0];
      }
      salesByDate[d] = (salesByDate[d] || 0) + (s.total_price || 0);
  });
  const sortedDates = Object.keys(salesByDate).sort();
  
  const salesCtx = document.getElementById('salesChart').getContext('2d');
  new Chart(salesCtx, {
      type: 'line',
      data: {
          labels: sortedDates.length ? sortedDates : ['No Data'],
          datasets: [{
              label: 'Daily Revenue (CAD)',
              data: sortedDates.length ? sortedDates.map(d => salesByDate[d]) : [0],
              borderColor: '#10b981',
              backgroundColor: 'rgba(16, 185, 129, 0.1)',
              borderWidth: 3,
              tension: 0.4,
              fill: true,
              pointRadius: 4,
              pointBackgroundColor: '#10b981'
          }]
      },
      options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
              y: { beginAtZero: true, grid: { color: 'rgba(160, 160, 160, 0.1)' } },
              x: { grid: { display: false } }
          }
      }
  });

  // 2. Category Donut
  const setValues = {};
  inventoryData.forEach(item => {
      const val = (item.market_price || 0) * (item.lots || []).reduce((q, l) => q + (l.qty||0), 0);
      const catName = item.category || 'Singles/Unknown';
      setValues[catName] = (setValues[catName] || 0) + val;
  });
  const setLabels = Object.keys(setValues).sort((a,b) => setValues[b] - setValues[a]).slice(0, 5);
  let otherVal = 0;
  Object.keys(setValues).sort((a,b) => setValues[b] - setValues[a]).slice(5).forEach(k => { otherVal += setValues[k]; });
  if (otherVal > 0) { setLabels.push('Other'); setValues['Other'] = otherVal; }
  
  const setChartData = setLabels.map(l => setValues[l]);

  const catCtx = document.getElementById('categoryChart').getContext('2d');
  new Chart(catCtx, {
      type: 'doughnut',
      data: {
          labels: setLabels.length ? setLabels : ['No Data'],
          datasets: [{
              data: setChartData.length ? setChartData : [1],
              backgroundColor: ['#3b82f6', '#8b5cf6', '#ec4899', '#f59e0b', '#10b981', '#6b7280'],
              borderWidth: 0,
              hoverOffset: 4
          }]
      },
      options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '70%',
          plugins: {
              legend: { position: 'bottom', labels: { usePointStyle: true, boxWidth: 8, font: {size: 11} } }
          }
      }
  });

  // 3. Ledger Chart (Volume/Transactions)
  const ledgerDates = {};
  activityData.forEach(act => {
      if(act.log_type === 'sale') {
         let d = 'Unknown';
         if(act.date) {
             const dt = new Date(act.date);
             if(!isNaN(dt.valueOf())) d = dt.toISOString().split('T')[0];
         }
         ledgerDates[d] = (ledgerDates[d] || 0) + 1;
      }
  });
  const lSorted = Object.keys(ledgerDates).sort();
  const ledgerCtx = document.getElementById('ledgerChart')?.getContext('2d');
  if(ledgerCtx) {
    new Chart(ledgerCtx, {
        type: 'bar',
        data: {
            labels: lSorted.length ? lSorted : ['No Data'],
            datasets: [{
                label: 'Transactions',
                data: lSorted.length ? lSorted.map(d => ledgerDates[d]) : [0],
                backgroundColor: 'rgba(56, 189, 248, 0.5)',
                borderRadius: 4,
                barPercentage: 0.6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { enabled: true } },
            scales: {
                y: { display: false, beginAtZero: true },
                x: { display: false }
            },
            layout: { padding: 0 }
        }
    });
  }
</script>

<!-- Receipt Image Modal -->
<dialog id="receipt_image_modal" class="modal">
  <div class="modal-box max-w-2xl p-4">
    <div class="flex justify-between items-center mb-3">
      <h3 class="font-bold text-lg">Sale Receipt</h3>
      <button onclick="document.getElementById('receipt_image_modal').close()" class="btn btn-sm btn-circle btn-ghost">✕</button>
    </div>
    <div id="receipt_modal_loading" class="flex justify-center py-8 hidden"><span class="loading loading-spinner loading-lg"></span></div>
    <img id="receipt_modal_img" src="" alt="Sale Receipt" class="w-full rounded-xl object-contain max-h-[70vh]" />
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
  // EST clock (handles EST/EDT automatically via America/New_York)
  (function tickClock() {
    const el = document.getElementById('est-clock');
    if (!el) return;
    const now = new Date();
    const date = now.toLocaleDateString('en-US', { timeZone: 'America/New_York', weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
    const time = now.toLocaleTimeString('en-US', { timeZone: 'America/New_York', hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const tz   = now.toLocaleTimeString('en-US', { timeZone: 'America/New_York', timeZoneName: 'short' }).split(' ').pop();
    el.textContent = date + '  ·  ' + time + ' ' + tz;
    setTimeout(tickClock, 1000);
  })();

  async function startSync() {
    const btn = document.getElementById('syncBtn');
    btn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Syncing...';
    btn.disabled = true;
    btn.classList.add('opacity-70');
    try {
      await fetch('/api/sync-prices', { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      const poll = setInterval(async () => {
        const r = await fetch('/api/sync-status');
        const d = await r.json();
        if (!d.running) {
          clearInterval(poll);
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" /></svg> Sync Prices';
          btn.disabled = false;
          btn.classList.remove('opacity-70');
        }
      }, 3000);
    } catch(e) {
      btn.innerHTML = 'Sync Prices';
      btn.disabled = false;
      btn.classList.remove('opacity-70');
    }
  }

  function openReceiptModal(saleId) {
    const img = document.getElementById('receipt_modal_img');
    const loader = document.getElementById('receipt_modal_loading');
    img.src = '';
    img.classList.add('hidden');
    loader.classList.remove('hidden');
    document.getElementById('receipt_image_modal').showModal();
    img.onload = () => { loader.classList.add('hidden'); img.classList.remove('hidden'); };
    img.onerror = () => { loader.classList.add('hidden'); img.alt = 'Image failed to load'; img.classList.remove('hidden'); };
    img.src = '/api/sale-image/' + saleId;
  }
</script>

