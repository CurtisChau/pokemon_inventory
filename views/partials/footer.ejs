          <input type="text" name="person_override" placeholder="Typing name..." class="input input-bordered input-sm w-full" />
        </label>
      </div>
      <div class="flex justify-end mt-4 sm:mt-0">
        <button type="button" class="btn mr-2" onclick="window.record_trade_modal.close()">Cancel</button>
        <button type="submit" class="btn btn-warning">Finalize Trade</button>
