      <div class="flex gap-4">
        <label class="form-control w-[45%] text-xs">
          <div class="label"><span class="label-text">Data Source</span></div>
          <select name="data_source" id="data_source_select" class="select select-bordered text-[13px]"><option value="tcgplayer">TCGPlayer API</option><option value="pricecharting">PriceChart API</option><option value="manual">Manual Entry</option></select>
        </label>
