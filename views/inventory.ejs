<%- include('partials/header') %>

<main class="flex-1 p-4 lg:p-8 w-full max-w-7xl mx-auto">
  <div class="flex flex-col gap-6">
    <!-- Header & Controls -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <h1 class="text-3xl font-extrabold tracking-tight">Inventory</h1>
      
      <div class="flex gap-2 w-full md:w-auto">
        <div class="relative flex-1 md:w-64">
          <input type="text" placeholder="Search cards..." class="input input-bordered w-full pl-10 rounded-full bg-base-100/50 focus:bg-base-100 transition-colors" />
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-1/2 -translate-y-1/2 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </div>
        <div class="join bg-base-200 p-1 rounded-full shadow-inner">
          <a href="/inventory?view=list" class="btn btn-sm join-item rounded-full border-none <%= view === 'list' ? 'bg-base-100 shadow-sm text-primary' : 'bg-transparent text-base-content/60 hover:bg-base-300' %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
          </a>
          <a href="/inventory?view=card" class="btn btn-sm join-item rounded-full border-none <%= view === 'card' ? 'bg-base-100 shadow-sm text-primary' : 'bg-transparent text-base-content/60 hover:bg-base-300' %>">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          </a>
        </div>
        <button class="btn btn-primary btn-sm rounded-full hidden md:flex font-bold px-4 shadow-primary/30 shadow-md" onclick="document.getElementById('add_item_modal').showModal()">+ Add Item</button>
      </div>
    </div>

    <% if (view === 'list') { %>
    <!-- List View -->
    <div class="overflow-x-auto bg-base-100 rounded-2xl shadow-sm border border-base-200/60">
      <table class="table table-zebra table-md w-full whitespace-nowrap">
        <thead>
          <tr class="bg-base-200/50 text-base-content/70 border-b border-base-200 text-sm">
            <th class="font-medium p-4 pl-6">Card Info</th>
            <th class="font-medium p-4">Set</th>
            <th class="font-medium p-4 text-right">Qty</th>
            <th class="font-medium p-4 text-right">Est. CoG</th>
            <th class="font-medium p-4 text-right">Market</th>
            <th class="font-medium p-4 text-center pr-6">Action</th>
          </tr>
        </thead>
        <tbody>
          <% inventory.forEach(item => { 
             let totalQty = item.lots.reduce((sum, l) => sum + l.qty, 0);
             if (totalQty === 0) return;
             let avgCog = item.lots.reduce((sum, l) => sum + (l.cog * l.qty), 0) / totalQty;
          %>
          <tr class="hover:bg-base-200/30 transition-colors">
            <td class="p-4 pl-6">
              <div class="flex items-center gap-4">
                <div class="avatar shadow-sm border border-base-300 rounded-lg overflow-hidden bg-base-200 flex items-center justify-center font-bold text-primary">
                  <div class="w-12 h-12 p-1 flex items-center justify-center">
                    <% if(item.image) { %><img src="<%= item.image %>" alt="<%= item.name %>" class="object-contain" /><% } else { %><%= item.name.charAt(0) %><% } %>
                  </div>
                </div>
                <div>
                  <div class="font-bold text-base text-base-content"><%= item.name %></div>
                  <div class="text-xs text-base-content/50 mt-0.5"><%= item.condition %></div>
                </div>
              </div>
            </td>
            <td class="p-4">
              <span class="badge badge-ghost badge-sm text-xs border-base-300"><%= item.set %></span>
            </td>
            <td class="p-4 text-right font-medium"><%= totalQty %></td>
            <td class="p-4 text-right text-base-content/70 text-sm">
                <div class="tooltip" data-tip="Lots: <%= item.lots.map(l => l.qty + ' @ $' + l.cog).join(', ') %>">
                  $<%= avgCog.toFixed(2) %> (Avg)
                </div>
            </td>
            <td class="p-4 text-right text-success font-bold tracking-tight"><%- item.market_price !== null ? '$' + item.market_price.toFixed(2) : '<span class="text-base-content/50 italic text-xs font-normal">N/A</span>' %></td>
            <td class="p-4 flex gap-2 justify-center items-center h-full pt-6 border-none">
               <% if(item.tcgplayer_url) { %>
                 <a href="<%= item.tcgplayer_url %>" target="_blank" class="btn btn-xs btn-ghost text-info hover:bg-info/10 tooltip tooltip-left" data-tip="View on TCGPlayer"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg></a>
               <% } %>
               <button class="btn btn-sm btn-ghost text-primary hover:bg-primary/10 rounded-lg font-medium" onclick="document.getElementById('record_sale_modal').showModal(); document.querySelector('#record_sale_modal select[name=\'item_id\']').value='<%= item.id %>'">Quick Sell</button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <!-- Card View -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 lg:gap-6">
      <% inventory.forEach(item => { 
         let totalQty = item.lots.reduce((sum, l) => sum + l.qty, 0);
         if (totalQty === 0) return;
         let avgCog = item.lots.reduce((sum, l) => sum + (l.cog * l.qty), 0) / totalQty;
      %>
      <div class="card bg-base-100 shadow-sm border border-base-200/60 overflow-hidden group hover:shadow-md hover:border-primary/30 transition-all duration-300">
        <figure class="px-4 pt-5 pb-2 relative flex items-center justify-center h-52 bg-gradient-to-b from-base-200/50 to-transparent">
          <% if(item.image) { %><img src="<%= item.image %>" alt="<%= item.name %>" class="rounded-xl drop-shadow-lg h-full object-contain group-hover:scale-105 transition-transform duration-500" /><% } else { %><div class="text-6xl font-black text-primary opacity-30"><%= item.name.charAt(0) %></div><% } %>
          <div class="absolute top-4 right-4 badge badge-primary font-bold shadow-md border-none">x<%= totalQty %></div>
        </figure>
        <div class="card-body p-4 pt-2 flex justify-end">
          <div class="text-center">
            <h2 class="font-bold text-sm text-base-content truncate"><%= item.name %></h2>
            <p class="text-[11px] text-base-content/50 truncate mt-0.5 uppercase tracking-wide"><%= item.set %></p>
          </div>
          <div class="divider my-1 opacity-50"></div>
          <div class="flex justify-between items-end mt-1">
            <div class="flex flex-col tooltip" data-tip="Lots: <%= item.lots.map(l => l.qty + ' @ $' + l.cog).join(', ') %>">
              <span class="text-[10px] text-base-content/50 uppercase font-medium cursor-help border-b border-dashed border-base-content/30">Est. CoG</span>
              <span class="text-xs font-semibold opacity-80">$<%= avgCog.toFixed(2) %></span>
            </div>
            <div class="flex flex-col items-end">
              <span class="text-[10px] text-base-content/50 uppercase font-medium">Market</span>
              <span class="text-sm font-black text-success tracking-tight"><%- item.market_price !== null ? '$' + item.market_price.toFixed(2) : '<span class="text-base-content/50 italic font-normal">N/A</span>' %></span>
            </div>
          </div>
          <div class="flex gap-2 w-full mt-3 opacity-0 group-hover:opacity-100 transition-opacity hidden lg:flex">
             <% if(item.tcgplayer_url) { %>
                <a href="<%= item.tcgplayer_url %>" target="_blank" class="btn btn-sm btn-outline btn-info flex-1 tooltip" data-tip="Open TCGPlayer"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg></a>
             <% } %>
             <button class="btn btn-primary btn-sm flex-[3] rounded-lg shadow-primary/20 shadow-lg" onclick="document.getElementById('record_sale_modal').showModal(); document.querySelector('#record_sale_modal select[name=\'item_id\']').value='<%= item.id %>'">Quick Sell</button>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
