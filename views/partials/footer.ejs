          <span class="text-xs uppercase opacity-60">Value Gaining (Market):</span>
          <div class="text-xl font-bold text-success" id="trade_receiving_total">$0.00</div>
        </div>
      </div>
      
    </div>
    
    <div class="modal-action bg-base-200 p-4 m-0 rounded-b-2xl flex flex-col sm:flex-row gap-4 justify-between items-center w-full flex-shrink-0">
      <div class="flex gap-2 w-full sm:w-1/2">
