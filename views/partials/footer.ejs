<script>
  function openEditModal(btn) {
      const dataStr = btn.getAttribute('data-item');
      if (!dataStr) return;
      
      const item = JSON.parse(atob(dataStr));
      
      document.getElementById('edit_item_id').value = item.id;
      document.getElementById('edit_item_name').value = item.name;
      document.getElementById('edit_item_set').value = item.set || item.set_name || '';
      document.getElementById('edit_item_condition').value = item.condition || 'Near Mint';
      document.getElementById('edit_item_category').value = item.category || 'Singles';
      document.getElementById('edit_market_price').value = item.market_price || '';
      document.getElementById('edit_item_qty').value = item.totalQty || 0;
      document.getElementById('edit_item_cog').value = item.avgCog !== undefined ? parseFloat(item.avgCog).toFixed(2) : '0.00';
      
      document.getElementById('edit_api_image_url').value = item.image || '';
      document.getElementById('edit_api_tcgplayer_url').value = item.tcgplayer_url || '';
      
      document.getElementById('edit_item_modal').showModal();
  }

  const editSearchInput = document.getElementById('edit_search_input');
  const editSearchResults = document.getElementById('edit_search_results');
  let editCurrentCards = [];
  let editSearchTimeout;

  editSearchInput?.addEventListener('input', (e) => {
    clearTimeout(editSearchTimeout);
    const q = e.target.value.trim();
    const source = document.getElementById('edit_data_source').value;
    if (q.length < 3) { editSearchResults.classList.add('hidden'); return; }
    
    editSearchTimeout = setTimeout(async () => {
      const endpoint = source === 'pricecharting' ? '/api/search/sealed?q=' : '/api/search?q=';
      const res = await fetch(endpoint + encodeURIComponent(q));
      const data = await res.json();
      
      if (source === 'pricecharting' && Array.isArray(data)) {
         editCurrentCards = data;
         editSearchResults.innerHTML = editCurrentCards.map((p, idx) => {
            return '<li class="p-3 hover:bg-base-200 cursor-pointer flex gap-3" onclick="selectEditCard('+idx+', \'pricecharting\')">' +
              '<div class="flex-1 text-sm leading-tight font-medium">' + p.productName + ' <span class="opacity-50 text-xs block">' + (p.consoleName||'Unk') + '</span></div>' +
              '<div class="font-bold text-success whitespace-nowrap">$' + Number(p.price).toFixed(2) + '</div>' +
            '</li>';
         }).join('');
         editSearchResults.classList.remove('hidden');
      } else if (data.data) {
        editCurrentCards = data.data;
        editSearchResults.innerHTML = editCurrentCards.map((card, idx) => {
            const price = card.tcgplayer?.prices?.normal?.market || card.tcgplayer?.prices?.holofoil?.market || 0;
            return '<li class="p-3 hover:bg-base-200 cursor-pointer flex gap-3" onclick="selectEditCard('+idx+', \'tcgplayer\')">' +
              '<img src="' + (card.images?.small || '') + '" class="w-6 h-8 object-contain bg-base-300 rounded-sm" />' +
              '<div class="flex-1 text-sm leading-tight font-medium">' + card.name + ' <span class="opacity-50 text-xs block">' + (card.set?.name||'Unk') + '</span></div>' +
              '<div class="font-bold text-success whitespace-nowrap">$' + Number(price).toFixed(2) + '</div>' +
            '</li>';
        }).join('');
        editSearchResults.classList.remove('hidden');
      }
    }, 500);
  });
  
  function selectEditCard(idx, source) {
      if (source === 'pricecharting') {
          const item = editCurrentCards[idx];
          document.getElementById('edit_item_name').value = item.productName || '';
          document.getElementById('edit_item_set').value = item.consoleName || 'Sealed';
          document.getElementById('edit_api_image_url').value = item.imageUri || '';
          let pcUrl = item.url ? item.url : `https://www.pricecharting.com/game/${(item.consoleName||'').toLowerCase().replace(/[^a-z0-9]+/g, '-')}/${(item.productName||'').toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
          document.getElementById('edit_api_tcgplayer_url').value = pcUrl;
      } else {
          const card = editCurrentCards[idx];
          document.getElementById('edit_item_name').value = card.name || '';
          document.getElementById('edit_item_set').value = card.set?.name || 'Unknown';
          document.getElementById('edit_api_image_url').value = card.images?.small || '';
          document.getElementById('edit_api_tcgplayer_url').value = card.tcgplayer?.url || '';
      }
      editSearchInput.value = '';
      editSearchResults.classList.add('hidden');
  }
</script>

<!-- Record Trade Modal -->
<dialog id="record_trade_modal" class="modal modal-bottom sm:modal-middle">
  <div class="modal-box w-11/12 max-w-4xl p-0 overflow-hidden max-h-[92dvh] flex flex-col">
